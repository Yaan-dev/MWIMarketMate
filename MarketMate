        getByBareId(bareId) { return this.get(`/items/${bareId}`); },

        /** 获取最低卖价挂单 */
        getBestAsk(itemHrid) {
            const data = this.get(itemHrid);
            if (!data?.asks?.length) return null;
            return data.asks.reduce((best, a) => (!best || a.price < best.price) ? a : best, null);
