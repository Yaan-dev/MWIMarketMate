    const _wsInventory = {
        _hashMap: new Map(),    // hash → { itemHrid, itemLocationHrid, enhancementLevel, count }
        _detailMap: new Map(),  // hrid → Map<enhancementLevel, count>（仅 inventory 的聚合视图）
